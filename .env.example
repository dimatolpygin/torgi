# ===== Целевой сайт =====
SITE_BASE_URL=https://gorod.it-minsk.by
# Минский Комаровский рынок
RINOK_ID=10
# Ассортимент: 1-картофель, 2-овощи, 3-зелень, 4-плоды, 5-ягоды, 6-яблоки
ASSORT_IDS=2

# ===== Тайминг =====
TZ_NAME=Europe/Minsk
PREPARE_LEAD_SECONDS=120
# true = не отправлять реальную заявку (безопасно для тестов)
DRY_RUN=true

# ===== Аккаунты (заполняются позже, на этапе 1/6) =====
# Формат: логин:пароль через запятую между аккаунтами
# ACCOUNTS=1121298c017rb8:607404

# ===== Postgres =====
PGHOST=postgres
PGPORT=5432
PGUSER=bron
PGPASSWORD=bron
PGDATABASE=bron

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
# Необязательно: TTL сессионной куки и флага «сегодня подано» (секунды)
# SESSION_TTL_SEC=43200
# DONE_TTL_SEC=259200

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
# Заранее заданные chat_id через запятую — это операторские чаты (роль dev,
# получают всё + состояние сервера). Подписываются ещё до кодового слова.
# TELEGRAM_CHAT_IDS=
# Кодовые слова для подписки с ролью. Формат: слово:роль:метка через запятую.
# Роли: wife (жена), husband (муж), dev (разработчик — надмножество).
# Жена/муж получают итоги брони и алерты; dev — ещё и состояние сервера.
# TELEGRAM_CODE_WORDS=komarovka-wife:wife:Жена,komarovka-muzh:husband:Муж,komarovka-dev:dev:Разработчик

# ===== Мониторинг сервера (этап 16) =====
# Dead-man's switch: URL проверки на healthchecks.io. Бот пингует его раз в N мс;
# если пинги прекратятся (сервер умер) — healthchecks.io сам уведомит разработчика
# (Telegram/e-mail настраивается в кабинете healthchecks.io). Пусто — мониторинг off.
# HEALTHCHECKS_URL=https://hc-ping.com/ВАШ-UUID
# HEALTHCHECKS_PING_MS=60000
# Pre-flight: слать разработчику «жив, готов к подаче» при ночном прогреве (true/false)
# HEALTH_PREFLIGHT=true

# ===== Логи =====
LOG_LEVEL=info
